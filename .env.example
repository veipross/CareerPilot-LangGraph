# qwen / deepseek
CAREERPILOT_LLM_PROVIDER=deepseek

# Qwen / DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key_here
CAREERPILOT_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CAREERPILOT_QWEN_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
CAREERPILOT_DEEPSEEK_BASE_URL=https://api.deepseek.com
CAREERPILOT_DEEPSEEK_MODEL=deepseek-v4-flash

# Common generation config
CAREERPILOT_LLM_TEMPERATURE=0.2
CAREERPILOT_LLM_MAX_TOKENS=2048

# Request timeout in seconds
CAREERPILOT_LLM_TIMEOUT=60
